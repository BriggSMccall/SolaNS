# SOLANS CLI / client configuration — copy to .env and fill in.
# Cluster: localnet | devnet | mainnet (devnet recommended for development)
SOLANS_CLUSTER=devnet
# Custom RPC/WS endpoints (override cluster defaults; e.g. a Helius URL)
SOLANS_RPC_URL=
SOLANS_WS_URL=
# Fee-payer / authority keypair (Solana CLI JSON format)
SOLANS_KEYPAIR=~/.config/solana/id.json
# Deployed program id (matches declare_id! / Anchor.toml)
SOLANS_PROGRAM_ID=7pVCKp81EHJi2DbUtUXAkk2b3VtrUZwj2hWDakXY2dMf
# Payment SPL mint + treasury token account (set after init-config)
SOLANS_MINT=
SOLANS_TREASURY=
